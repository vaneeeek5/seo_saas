// SEO Content Factory - Prisma Schema
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ProjectStatus {
  ACTIVE
  PAUSED
  ARCHIVED
}

enum TaskStatus {
  PENDING
  QUEUED
  PROCESSING
  COMPLETED
  FAILED
  CANCELLED
}

enum ContentStatus {
  DRAFT
  PENDING_REVIEW
  APPROVED
  REJECTED
  PUBLISHED
}

enum UserRole {
  OWNER
  ADMIN
  EDITOR
  VIEWER
}

enum IntegrationProvider {
  OPENAI
  WEBHOOK
  GSC
  METRIKA
  TELEGRAM
  GEMINI
  ANTHROPIC
  WORDSTAT
  AHREFS
  WORDPRESS_CMS
  CUSTOM_WEBHOOK
  YANDEX_WORDSTAT
}

model Organization {
  id           String                  @id @default(uuid())
  name         String
  createdAt    DateTime                @default(now())
  updatedAt    DateTime                @updatedAt
  projects     Project[]
  users        User[]
  integrations IntegrationConnection[]

  @@map("organizations")
}

model User {
  id             String       @id @default(uuid())
  email          String       @unique
  name           String?
  role           UserRole     @default(EDITOR)
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@map("users")
}

model Project {
  id               String                  @id @default(uuid())
  organizationId   String
  organization     Organization            @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name             String
  domain           String
  targetRegion     String?                 @default("global")
  language         String?                 @default("en")
  status           ProjectStatus           @default(ACTIVE)
  autopilotEnabled Boolean                 @default(true)
  articlesPerDay   Int?                    @default(1)
  articlesPerWeek  Int?                    @default(7)
  includeKeywords  String[]
  excludeKeywords  String[]
  createdAt        DateTime                @default(now())
  updatedAt        DateTime                @updatedAt
  websites         Website[]
  tasks            Task[]
  keywords         Keyword[]
  clusters         Cluster[]
  contentAssets    ContentAsset[]
  publications     Publication[]
  integrations     IntegrationConnection[]

  @@map("projects")
}

model IntegrationConnection {
  id             String              @id @default(uuid())
  projectId      String
  project        Project             @relation(fields: [projectId], references: [id], onDelete: Cascade)
  organizationId String
  organization   Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  provider       IntegrationProvider
  name           String
  /// SECURITY MANDATE: This field MUST be encrypted via AES-256 (AES-256-GCM) at the service layer
  /// (EncryptionService) prior to persistence. Storing plain text API keys is strictly prohibited.
  encryptedKey   String              @db.Text
  iv             String
  authTag        String
  maskedKey      String
  config         Json?
  isActive       Boolean             @default(true)
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  @@map("integration_connections")
}

model Website {
  id               String   @id @default(uuid())
  projectId        String
  project          Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  url              String
  cmsType          String?  @default("wordpress")
  autopilotEnabled Boolean  @default(true)
  articlesPerDay   Int?     @default(1)
  articlesPerWeek  Int?     @default(7)
  includeKeywords  String[]
  excludeKeywords  String[]
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@map("websites")
}

model Task {
  id        String     @id @default(uuid())
  projectId String
  project   Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  type      String
  status    TaskStatus @default(QUEUED)
  progress  Int        @default(0)
  message   String?
  error     String?
  payload   Json?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@map("tasks")
}

model Keyword {
  id         String   @id @default(uuid())
  projectId  String
  project    Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  term       String
  searchVol  Int?     @default(0)
  difficulty Int?     @default(0)
  clusterId  String?
  cluster    Cluster? @relation(fields: [clusterId], references: [id], onDelete: SetNull)
  createdAt  DateTime @default(now())

  @@map("keywords")
}

model Cluster {
  id        String        @id @default(uuid())
  projectId String
  project   Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name      String
  status    ContentStatus @default(DRAFT)
  keywords  Keyword[]
  createdAt DateTime      @default(now())

  @@map("clusters")
}

model ContentAsset {
  id          String            @id @default(uuid())
  projectId   String
  project     Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  title       String
  slug        String
  body        String?           @db.Text
  status      ContentStatus     @default(DRAFT)
  wordCount   Int?              @default(0)
  metaTitle   String?
  metaDesc    String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  publication Publication?
  analytics   ArticleAnalytics?

  @@map("content_assets")
}

model ArticleAnalytics {
  id             String       @id @default(uuid())
  contentAssetId String       @unique
  contentAsset   ContentAsset @relation(fields: [contentAssetId], references: [id], onDelete: Cascade)
  impressions    Int          @default(0)
  clicks         Int          @default(0)
  position       Float        @default(0.0)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@map("article_analytics")
}

model Publication {
  id             String       @id @default(uuid())
  projectId      String
  project        Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  contentAssetId String       @unique
  contentAsset   ContentAsset @relation(fields: [contentAssetId], references: [id], onDelete: Cascade)
  externalUrl    String?
  publishedAt    DateTime?
  createdAt      DateTime     @default(now())

  @@map("publications")
}
